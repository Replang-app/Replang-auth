# Service Auth — variables d'environnement (copier en .env)

NODE_ENV=development
AUTH_PORT=3001

# Connexion à PostgreSQL. En local hors Docker : host = localhost.
# Dans Docker (réseau interne) : host = postgres.
DATABASE_URL=postgresql://replang:changeme_dev_password@localhost:5432/replang?schema=public

# Secret de signature Better-Auth — générer : openssl rand -hex 32
BETTER_AUTH_SECRET=changeme_generate_a_long_random_secret

# URL publique du service Auth (sert de baseURL Better-Auth)
BETTER_AUTH_URL=http://localhost:3001

# Origines frontend autorisées (CORS), séparées par des virgules
TRUSTED_ORIGINS=http://localhost:3000
